// ============================================================
// PostgreSQL 生产环境 Schema
// 使用方式：
//   1. 确保 PostgreSQL 已安装并运行
//   2. 创建数据库: createdb plotforge
//   3. 复制 .env.example 为 .env.production 并填入连接字符串
//   4. 运行: npx prisma db push --schema=prisma/schema-postgresql.prisma
//
// 从 SQLite 迁移到 PostgreSQL 的优势：
//   - 更好的并发性能（多用户同时写入）
//   - 支持 JSONB 查询（复杂属性如 habits、tags）
//   - 支持全文搜索（世界观/章节内容搜索）
//   - 生产级备份和复制支持
//   - 更强的数据完整性约束
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  works Work[]

  @@map("users")
}

model Work {
  id        String   @id @default(cuid())
  title     String
  genre     String
  stage     String   @default("planning")
  summary   String   @default("")
  theme     String   @default("obsidian")
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  characters     Character[]
  chapters       Chapter[]
  scenes         Scene[]
  loreEntries    LoreEntry[]
  factions       Faction[]
  snapshots      Snapshot[]
  aiRecords      AiGenerationRecord[]
  conflictRecords ConflictRecord[]

  @@index([userId])
  @@map("works")
}

model Character {
  id          String   @id @default(cuid())
  workId      String
  name        String
  role        String   @default("")
  appearance  String   @default("")
  personality String   @default("")
  backstory   String   @default("")
  habits      String   @default("[]")
  catchphrase String   @default("")
  weakness    String   @default("")
  mission     String   @default("")
  taboo       String   @default("")
  arc         String   @default("")
  biography   String   @default("")
  avatar      String   @default("")
  tags        String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  work          Work           @relation(fields: [workId], references: [id], onDelete: Cascade)
  relationNodes RelationNode[]

  @@index([workId])
  @@index([name])
  @@map("characters")
}

model Chapter {
  id             String   @id @default(cuid())
  workId         String
  title          String
  orderIndex     Int      @default(0)
  status         String   @default("draft")
  hook           String   @default("")
  contentPreview String   @default("")
  branchCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  work       Work            @relation(fields: [workId], references: [id], onDelete: Cascade)
  contents   ChapterContent[]
  branches   PlotBranch[]
  suggestions AiSuggestion[]

  @@index([workId])
  @@index([orderIndex])
  @@map("chapters")
}

model ChapterContent {
  id        String   @id @default(cuid())
  chapterId String
  title     String   @default("")
  content   String   @default("") // @db.Text (PostgreSQL 不需要，原生支持大文本)
  branchId  String?
  orderIndex Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("chapter_contents")
}

model PlotBranch {
  id           String   @id @default(cuid())
  chapterId    String
  title        String
  summary      String   @default("")
  tension      String   @default("medium")
  aiGenerated  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("plot_branches")
}

model AiSuggestion {
  id        String   @id @default(cuid())
  chapterId String
  type      String   @default("continuation")
  label     String
  content   String   @default("")
  tension   String   @default("medium")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([chapterId])
  @@map("ai_suggestions")
}

model Scene {
  id           String   @id @default(cuid())
  workId       String
  name         String
  environment  String   @default("")
  weather      String   @default("")
  timeSetting  String   @default("")
  dangerZones  String   @default("[]")
  residents    String   @default("[]")
  chapterId    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@map("scenes")
}

model LoreEntry {
  id           String   @id @default(cuid())
  workId       String
  category     String
  title        String
  summary      String   @default("")
  linkedTitles String   @default("[]")
  riskLevel    String   @default("stable")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([category])
  @@map("lore_entries")
}

model Faction {
  id        String   @id @default(cuid())
  workId    String
  name      String
  stance    String   @default("")
  doctrine  String   @default("")
  leader    String   @default("")
  influence Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  work      Work         @relation(fields: [workId], references: [id], onDelete: Cascade)
  edgesFrom FactionEdge[] @relation("FactionEdgeSource")
  edgesTo   FactionEdge[] @relation("FactionEdgeTarget")

  @@index([workId])
  @@map("factions")
}

model FactionEdge {
  id        String   @id @default(cuid())
  sourceId  String
  targetId  String
  edgeType  String   @default("")
  note      String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source Faction @relation("FactionEdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Faction @relation("FactionEdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([targetId])
  @@map("faction_edges")
}

model Snapshot {
  id        String   @id @default(cuid())
  workId    String
  scopeType String
  title     String
  summary   String   @default("")
  data      String   @default("{}") // JSON 格式的快照数据
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@map("snapshots")
}

model AiGenerationRecord {
  id           String   @id @default(cuid())
  workId       String
  moduleType   String
  model        String
  promptDigest String   @default("")
  status       String   @default("ready")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@map("ai_generation_records")
}

model ConflictRecord {
  id         String   @id @default(cuid())
  workId     String
  sourceType String
  title      String
  message    String   @default("")
  severity   String   @default("medium")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  work Work @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@index([workId])
  @@index([severity])
  @@map("conflict_records")
}

model RelationNode {
  id          String   @id @default(cuid())
  characterId String
  label       String
  avatar      String   @default("")
  x           Float    @default(0)
  y           Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@map("relation_nodes")
}

model RelationEdge {
  id            String   @id @default(cuid())
  sourceId      String
  targetId      String
  relationType  String
  intimacyLevel Int      @default(0)
  conflictLevel Int      @default(0)
  note          String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sourceId])
  @@index([targetId])
  @@map("relation_edges")
}
